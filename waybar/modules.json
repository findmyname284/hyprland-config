{
    "hyprland/workspaces": {
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "kitty"
        ],
        "rewrite": {
            "Chrome Web Browser": "Chrome",
            "Foot Server": "Terminal"
        }
    },
    "hyprland/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true,
        "max-length": 30
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
        "format-bluetooth-muted": "у°—ї {icon}пЉ” {format_source}",
        "format-muted": "п‘¦  Muted",
        "format-source": "{volume}% п„°",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": [
                "пЂ¦",
                "пЂЁ ",
                "пЂЁ "
            ]
        },
        "scroll-step": 2,
        "on-click": "pamixer -t"
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "п„° {volume}%",
        "format-source-muted": "п„±  Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },
    "bluetooth": {
        "format": "пЉ“ {status}",
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "у°‚„  {capacity}%",
        "format-plugged": "п‡¦  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-full": "{icon}  {capacity}%",
        "format-icons": [
            "п‰„",
            "п‰ѓ",
            "п‰‚",
            "п‰Ѓ",
            "п‰Ђ"
        ]
    },
    "network": {
        "format-wifi": "п‡« {signalStrength}%",
        "format-ethernet": "{cidr} оЅ„",
        "format-disconnected": "у°–Є",
        "tooltip-format-wifi": "п‡«  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "оЅ„ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "nm-connection-editor"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "format": "<span color='#fab387'>пЂ—</span> {:%H:%M %a}",
        "tooltip-format": "<big><span color='#cdd6f4'>{:%Y %B}</span></big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "<span color='#eba0ac'>пЃі</span> <span color='#cdd6f4'>{:%Y-%m-%d}</span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#cdd6f4'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weeks": "<span color='#f5c2e7'><b>W{}</b></span>",
                "weekdays": "<span color='#f5c2e7'><b>{}</b></span>",
                "today": "<span color='#eba0ac'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "hyprland/language": {
        "format": "у°ЊЏ {}",
        "format-en": "EN",
        "format-kk": "KZ"
    },
    "disk": {
        "interval": 30,
        "format": "о·© {percentage_used}%",
        "path": "/home/findmyname",
        "on-click": "(pgrep missioncenter || nohup missioncenter > /dev/null 2>&1 &)"
    },
    "cpu": {
        "interval": 5,
        "format": "п’ј {usage}%",
        "on-click": "(pgrep missioncenter || nohup missioncenter > /dev/null 2>&1 &)"
    },
    "memory": {
        "format": "ої… {}%",
        "on-click": "(pgrep missioncenter || nohup missioncenter > /dev/null 2>&1 &)"
    },
    "custom/exit": {
        "format": "пЂ‘ ",
        "on-click": "wlogout",
        "tooltip": false,
        "spacing": 10
    },
    "custom/archicon": {
        "format": "пЊѓ",
        "on-click": "sleep 0.1; kitty -e fish",
        "on-click-right": "sleep 0.2; ~/.config/rofi/launchers/type-6/launcher.sh",
        "tooltip": false
    },
    "custom/cava_mviz": {
        "exec": "~/.config/waybar/scripts/WaybarCava.sh",
        "format": "{}"
    },
    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 3600,
        "exec": "~/.config/waybar/scripts/venv/bin/python ~/.config/waybar/scripts/waybar-wttr.py",
        "return-type": "json"
    }
}
