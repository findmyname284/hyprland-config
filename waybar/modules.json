{
    "hyprland/workspaces": {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
            "Alacritty"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Foot Server": "Terminal"
        }
    },
    "hyprland/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
        "format-muted": "’Ü® Muted",
        "format-source": "{volume}% ’ä░",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’¢É",
            "headset": "’¢É",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": [
                "’Ć”",
                "’Ć© ",
                "’Ć© "
            ]
        },
        "scroll-step": 2,
        "on-click": "pamixer -t"
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "’ä░ {volume}%",
        "format-source-muted": "’ä▒ Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },
    "bluetooth": {
        "format": "’Ŗō {status}",
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "’Ś¦  {capacity}%",
        "format-plugged": "’ć”  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-full": "{icon}  {capacity}%",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ]
    },
    "network": {
        "format-wifi": "’ć½ {signalStrength}%",
        "format-ethernet": "{cidr} ’×¢",
        "format-disconnected": "¾░¢¬",
        "tooltip-format-wifi": "’ć½  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
        "tooltip-format-ethernet": "’×¢ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "nm-connection-editor"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "clock": {
        "format": "{:%H:%M %a}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "disk": {
        "interval": 30,
        "format": "ŅĘ® {percentage_used}%",
        "path": "/home/bibarys",
        "on-click": "(pgrep htop || kitty -e htop)"
    },
    "cpu": {
        "interval": 5,
        "format": "’Æ╝ {usage}%",
        "on-click": "(pgrep htop || kitty -e htop)"
    },
    "memory": {
        "format": "Ņ┐ģ {}%",
        "on-click": "(pgrep htop || kitty -e htop)"
    },
    "custom/exit": {
        "format": "’Ćæ ",
        "on-click": "wlogout",
        "tooltip": false,
        "spacing": 10
    },
    "custom/archicon": {
        "format": "’īā",
        "on-click": "sleep 0.1; kitty -e fish",
        "on-click-right": "sleep 0.2; (pgrep wofi || wofi --show drun)",
        "tooltip": false
    },
    "custom/audio-visualizer": {
        "format": "{}",
        // "exec": "~/.config/waybar/visualizer_script.sh",
        // "return-type": "json",
        // "interval": 1
    },
    "custom/weather": {
        "tooltip": true,
        "format": "{}",
        "interval": 30,
        "exec": "~/.config/waybar/scripts/waybar-wttr.py",
        "return-type": "json"
    }
}